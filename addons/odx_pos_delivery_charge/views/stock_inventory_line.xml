<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_inventory_line_search_inherit" model="ir.ui.view">
        <field name="name">stock.inventory.line.search.inherit</field>
        <field name="model">stock.inventory.line</field>
        <field name="inherit_id" ref="stock.stock_inventory_line_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='product_id']" position="before">
                <field name="barcode" string="Barcode"/>
            </xpath>
        </field>
    </record>
</odoo>
