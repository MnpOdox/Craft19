<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="inherited_pos_config_form" model="ir.ui.view">
        <field name="name">pos.config.form.inherit</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/div[hasclass('o_settings_container')][1]" position="after">
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box" id="disc">
                        <div class="o_setting_left_pane">
                            <field name="disc_button"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="disc_button"/>
                            <div class="text-muted">Hide amount discount button in POS</div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="price">
                        <div class="o_setting_left_pane">
                            <field name="price_button"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="price_button"/>
                            <div class="text-muted">Hide price edit button in POS</div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box" id="show_product_price">
                        <div class="o_setting_left_pane">
                            <field name="show_product_price"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="show_product_price"/>
                            <div class="text-muted">Show product price on the POS screen</div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
