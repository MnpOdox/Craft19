<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="odx_pos_delivery_charge.ProductCardPrice" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-content')]" position="attributes">
            <attribute name="t-att-class">{'d-flex flex-column justify-content-start' : !props.isComboPopup, 'my-1': props.isComboPopup and !props.imageUrl}</attribute>
        </xpath>
        <xpath expr="//div[hasclass('product-name')]" position="before">
            <div t-if="this.showProductPrice" class="product-price w-100 text-end text-muted small lh-sm mb-1">
                <t t-esc="this.displayPrice"/>
            </div>
        </xpath>
    </t>
</templates>
