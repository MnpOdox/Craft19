<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_book_receivable_form" model="ir.ui.view">
        <field name="name">receivable.book.form</field>
        <field name="model">receivable.book</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button id="button_confirm" string="Confirm" class="btn-primary" name="action_confirm"
                            type="object" invisible="state in ('confirm', 'close')"/>

                    <button id="button_done" string="Done" class="btn-primary" name="action_done"
                            type="object" groups="odx_books.group_book_manager" invisible="state != 'confirm'"/>

                    <button id="button_draft" string="Set to Draft" class="btn-primary" name="action_draft"
                            type="object"  groups="odx_books.group_book_manager" invisible="state != 'confirm'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,close,confirm"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state in ('confirm', 'close')"/>
                        </group>
                        <group>
                            <field name="current_date"/>
                            <field name="company_id" invisible="1"/>

                        </group>
                    </group>
                    <notebook>
                        <!-- one2many fields -->

                        <page string="Receivable Line" name="receivable_details" invisible="state == 'draft'">
                            <field name="receivable_line_ids" readonly="state == 'close'">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="amount"/>
                                    <field name="receivable_id" invisible="1"/>
                                    <field name="company_id" invisible="1"/>
                                </list>

                                <form>
                                    <group>
                                        <field name="date"/>
                                        <field name="description"/>
                                        <field name="amount"/>
                                        <field name="company_id" invisible="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <record id="view_book_receivable_tree" model="ir.ui.view">
        <field name="name">receivable.book.tree</field>
        <field name="model">receivable.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="current_date"/>
                <field name="partner_id"/>
                <field name="balance"/>
                <field name="state" widget="badge" decoration-success="state == 'close'" decoration-info="state == 'draft'" decoration-warning= "state == 'confirm'" />
            </list>
        </field>
    </record>

    <record id="view_receivable_book_search" model="ir.ui.view">

        <field name="name">receivable.book.search</field>
        <field name="model">receivable.book</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="current_date"/>
                <field name="state"/>
                <filter string="Month" name="group_current_month" context="{'group_by':'current_date:month'}"/>
                <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
            </search>
        </field>

    </record>

    <record id="action_receivable_book" model="ir.actions.act_window">
        <field name="name">Receivable Book</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">receivable.book</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
            id="menu_receivable_books"
            name="Receivable"
            parent="menu_books_root"
            action="action_receivable_book"
            sequence="40"
    />

</odoo>
