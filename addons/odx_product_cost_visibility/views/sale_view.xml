<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sale_margin_form_restrict" model="ir.ui.view">
        <field name="name">sale.order.margin.restrict.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list//field[@name='margin']" position="attributes">
                <attribute name="groups">sales_team.group_sale_manager,point_of_sale.group_pos_manager,base.group_system</attribute>
            </xpath>
            <xpath expr="//field[@name='margin']" position="attributes">
                <attribute name="groups">sales_team.group_sale_manager,point_of_sale.group_pos_manager,base.group_system</attribute>
            </xpath>
        </field>
    </record>
</odoo>
