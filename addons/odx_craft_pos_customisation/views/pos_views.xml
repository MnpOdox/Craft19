<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Inherit POS Order Form View to Modify it -->
        <record id="pos_inherit_form_view" model="ir.ui.view">
            <field name="name">pos.packing</field>
            <field name="model">pos.order</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='refund']" position="after">
                    <button
                        name="action_open_payment_method_change_wizard"
                        type="object"
                        string="Change Payment Method"
                        groups="point_of_sale.group_pos_manager"
                        invisible="state != 'paid' or account_move or session_id.state in ['closing_control', 'closed']"/>
                </xpath>
                <xpath expr="//group[@name='order_fields']" position="after">
                    <group>
                        <group>
                            <field name="courier_id"/>
                            <field name="tracking_number"/>
                        </group>
                        <group>
                            <field name="online_order"/>
                            <field name="crm_sale"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="pos_inherit_search_view" model="ir.ui.view">
            <field name="name">pos.order.search.sale.type.filters</field>
            <field name="model">pos.order</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='order_date']" position="before">
                    <separator/>
                    <filter name="online_sales" string="Online Sales" domain="[('online_order', '=', True)]"/>
                    <filter name="crm_sales" string="CRM Sales" domain="[('crm_sale', '=', True)]"/>
                    <filter
                        name="walking_sales"
                        string="Walking Customer"
                        domain="[('online_order', '=', False), ('crm_sale', '=', False)]"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
