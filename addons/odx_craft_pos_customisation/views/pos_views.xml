<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Inherit POS Order Form View to Modify it -->
        <record id="pos_inherit_form_view" model="ir.ui.view">
            <field name="name">pos.packing</field>
            <field name="model">pos.order</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='refund']" position="after">
                    <button
                        name="action_open_payment_method_change_wizard"
                        type="object"
                        string="Change Payment Method"
                        groups="point_of_sale.group_pos_manager"
                        invisible="state != 'paid' or account_move or session_id.state in ['closing_control', 'closed']"/>
                </xpath>
                <xpath expr="//group[@name='order_fields']" position="after">
                    <group>
                        <group>
                            <field name="courier_id"/>
                            <field name="tracking_number"/>
                        </group>
                        <group>
                            <field name="online_order"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
