<odoo>
    <record id="paperformat_barcode" model="report.paperformat">
        <field name="name">Product Barcode</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="page_height">50</field>
        <field name="page_width">32</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0.50</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="dpi">350</field>
    </record>
    <record id="product_barcode_report" model="ir.actions.report">
        <field name="name">Barcode Craft- Normal</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">odx_barcode_print.report_barcode_in_products</field>
        <field name="report_file">odx_barcode_print.report_barcode_in_products</field>
        <field name="print_report_name">'Products barcode - %s' % (object.name)</field>
        <field name="paperformat_id" ref="odx_barcode_print.paperformat_barcode"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

    <record id="paperformat_barcode_la_beaute" model="report.paperformat">
        <field name="name">Barcode La Beaute</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="page_height">80</field>
        <field name="page_width">10</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="dpi">300</field>
    </record>
    <record id="product_barcode_report_la_beaute" model="ir.actions.report">
        <field name="name">Barcode La Beaute- Tag</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">odx_barcode_print.report_barcode_in_products_la_beaute</field>
        <field name="report_file">odx_barcode_print.report_barcode_in_products_la_beaute</field>
        <field name="print_report_name">'Products barcode - %s' % (object.name)</field>
        <field name="paperformat_id" ref="odx_barcode_print.paperformat_barcode_la_beaute"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>


    ################################################################################
   <record id="paperformat_barcode_labeaute_normal" model="report.paperformat">
        <field name="name">Product Barcode la beaute normal</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="page_height">50</field>
        <field name="page_width">32</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0.50</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="dpi">300</field>
    </record>
    <record id="product_barcode_report_labeaute_normal" model="ir.actions.report">
        <field name="name">Barcode La Beaute -Normal</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">odx_barcode_print.report_barcode_in_products_labeaute_normal</field>
        <field name="report_file">odx_barcode_print.report_barcode_in_products_labeaute_normal</field>
        <field name="print_report_name">'Products barcode - %s' % (object.name)</field>
        <field name="paperformat_id" ref="odx_barcode_print.paperformat_barcode_labeaute_normal"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
