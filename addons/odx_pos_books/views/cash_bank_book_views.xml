<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_book_head_form_pos_drawer_transfer" model="ir.ui.view">
        <field name="name">book.head.form.pos.drawer.transfer</field>
        <field name="model">book.head</field>
        <field name="inherit_id" ref="odx_books.view_book_head_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='auto_expense']" position="after">
                <field name="pos_drawer_transfer"/>
            </xpath>
        </field>
    </record>

    <record id="view_pos_cash_book_line_list" model="ir.ui.view">
        <field name="name">cash.book.line.pos.list</field>
        <field name="model">cash.book.line</field>
        <field name="arch" type="xml">
            <list string="POS Cash Book Lines" create="0" delete="0" edit="0">
                <field name="date"/>
                <field name="name_id" string="Cash Book"/>
                <field name="pos_source_type"/>
                <field name="pos_payment_method_id"/>
                <field name="head_id"/>
                <field name="description"/>
                <field name="amount" sum="Total"/>
                <field name="balance"/>
                <field name="pos_statement_line_id" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_pos_cash_book_line_form" model="ir.ui.view">
        <field name="name">cash.book.line.pos.form</field>
        <field name="model">cash.book.line</field>
        <field name="arch" type="xml">
            <form string="POS Cash Book Line" create="0" delete="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="name_id" string="Cash Book"/>
                            <field name="head_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="balance"/>
                            <field name="pos_source_type"/>
                            <field name="pos_payment_method_id"/>
                            <field name="pos_statement_line_id"/>
                            <field name="pos_session_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_bank_book_line_list" model="ir.ui.view">
        <field name="name">bank.book.line.pos.list</field>
        <field name="model">bank.book.line</field>
        <field name="arch" type="xml">
            <list string="POS Bank Book Lines" create="0" delete="0" edit="0">
                <field name="date"/>
                <field name="name_id" string="Bank Book"/>
                <field name="pos_source_type"/>
                <field name="pos_payment_method_id"/>
                <field name="head_id"/>
                <field name="description"/>
                <field name="amount" sum="Total"/>
                <field name="balance"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_pos_bank_book_line_form" model="ir.ui.view">
        <field name="name">bank.book.line.pos.form</field>
        <field name="model">bank.book.line</field>
        <field name="arch" type="xml">
            <form string="POS Bank Book Line" create="0" delete="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="name_id" string="Bank Book"/>
                            <field name="head_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="balance"/>
                            <field name="pos_source_type"/>
                            <field name="pos_payment_method_id"/>
                            <field name="pos_session_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cash_book_form_pos_mapping" model="ir.ui.view">
        <field name="name">cash.book.form.pos.mapping</field>
        <field name="model">cash.book</field>
        <field name="inherit_id" ref="odx_books.view_cash_book_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='end_date']" position="after">
                <field name="pos_payment_method_ids" widget="many2many_tags" domain="[('journal_id.type', '=', 'cash'), ('company_id', '=', company_id)]"
                       options="{'no_create': True}" readonly="state in ('done', 'cancel')"/>
                <field name="pos_sales_head_id" domain="[('cash', '=', True)]"
                       options="{'no_create': True}" readonly="state in ('done', 'cancel')"/>
            </xpath>
            <xpath expr="//field[@name='cash_line_ids']/list/field[@name='description']" position="after">
                <field name="pos_source_type" optional="hide"/>
                <field name="pos_session_id" optional="hide"/>
                <field name="pos_payment_method_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_bank_book_form_pos_mapping" model="ir.ui.view">
        <field name="name">bank.book.form.pos.mapping</field>
        <field name="model">bank.book</field>
        <field name="inherit_id" ref="odx_books.view_bank_book_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='end_date']" position="after">
                <field name="pos_payment_method_ids" widget="many2many_tags" domain="[('journal_id.type', '=', 'bank'), ('company_id', '=', company_id)]"
                       options="{'no_create': True}" readonly="state in ('done', 'cancel')"/>
                <field name="pos_sales_head_id" domain="[('bank', '=', True)]"
                       options="{'no_create': True}" readonly="state in ('done', 'cancel')"/>
            </xpath>
            <xpath expr="//field[@name='bank_line_ids']/list/field[@name='description']" position="after">
                <field name="pos_source_type" optional="hide"/>
                <field name="pos_session_id" optional="hide"/>
                <field name="pos_payment_method_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
