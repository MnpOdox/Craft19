<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_company_customisation" model="ir.ui.view">
        <field name="name">res.company.form.customisation</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="automatic_delivery_validation" string="Automatic Delivery Validation"/>
            </xpath>
        </field>
    </record>
</odoo>